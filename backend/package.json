{
  "name": "voitureprepa-backend",
  "version": "0.1.0",
  "description": "Backend Node.js pour VoiturePrepa.fr — squelette de démarrage (auth + annonces + admin). À compléter selon le cahier des charges.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "node --watch --env-file=.env src/server.js",
    "migrate": "node --env-file=.env src/migrate.js",
    "test:smoke": "node tests/smoke.js"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/secure-session": "^7.5.1",
    "@fastify/static": "^7.0.4",
    "argon2": "^0.40.3",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "nodemailer": "^6.9.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {}
}
